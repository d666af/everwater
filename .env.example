# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram ID-ы администраторов (через запятую без пробелов)
ADMIN_IDS=[123456789,987654321]

# URL Mini App (ваш домен или IP:PORT фронтенда)
# Пример: https://water.example.com  или  http://1.2.3.4:3000
MINI_APP_URL=http://YOUR_SERVER_IP:3000

# ─── База данных ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=StrongPasswordHere
POSTGRES_DB=waterbot

# ─── Порт фронтенда ───────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# ─── Оплата ───────────────────────────────────────────────────────────────────
PAYMENT_CARD=0000 0000 0000 0000
PAYMENT_HOLDER=Иванов Иван

# ─── Скидка за бутылки ────────────────────────────────────────────────────────
# Тип: fixed (фиксированная сумма) или percent (процент)
BOTTLE_DISCOUNT_TYPE=fixed
BOTTLE_DISCOUNT_VALUE=50

# ─── Секретный ключ (сгенерируйте: openssl rand -hex 32) ──────────────────────
SECRET_KEY=change-me-to-random-string
